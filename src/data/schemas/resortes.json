{
  "$schema": "https://isd-colchones.com/schemas/resortes-v1.json",
  "version": "1.0.0",
  "module": "resortes",
  "description": "Producción de resortes para colchones",
  "lastUpdated": "2025-01-15",

  "allowedProductTypes": [
    { "id": "resorte_bonnell", "name": "Resorte Bonnell", "examples": ["Bonnell 2.2", "Bonnell 2.5"] },
    { "id": "resorte_continuous", "name": "Resorte Continuous", "examples": ["Continuous 6", "Continuous 8"] },
    { "id": "resorte_pocket", "name": "Resorte Pocket", "examples": ["Pocket 1.8", "Pocket 2.0"] },
    { "id": "resorte_mirror", "name": "Resorte Mirror", "examples": ["Mirror tech"] },
    { "id": "resorte_lastex", "name": "Resorte Lastex", "examples": ["Lastex regular"] },
    { "id": "otro", "name": "Otro", "examples": [] }
  ],

  "validation": {
    "required": ["trabajador", "dni", "turno", "fecha", "producto", "cantidad", "maquina"],
    "numeric": ["cantidad"],
    "dateFormat": "YYYY-MM-DD"
  },

  "fieldMappings": {
    "trabajador": { "aliases": ["trabajador", "worker", "nombre", "name", "empleado"] },
    "dni": { "aliases": ["dni", "cedula", "ci", "id"] },
    "turno": { "aliases": ["turno", "shift", "jornada"] },
    "fecha": { "aliases": ["fecha", "date", "dia"] },
    "producto": { "aliases": ["producto", "tipo", "name", "articulo"] },
    "cantidad": { "aliases": ["cantidad", "qty", "units", "cant"] },
    "maquina": { "aliases": ["maquina", "machine", "equipo"] },
    "outputMaquina": { "aliases": ["outputMaquina", "output", "lectura"] },
    "calidad": { "aliases": ["calidad", "quality", "grade"] }
  },

  "turnos": ["Mañana", "Tarde", "Noche"],

  "sampleRecords": [
    {
      "trabajador": "Roberto Martínez",
      "dni": "55667788",
      "turno": "Mañana",
      "fecha": "2025-01-15",
      "producto": "Resorte Bonnell 2.2",
      "cantidad": 120,
      "maquina": "BOB-01",
      "outputMaquina": 450,
      "calidad": "A"
    }
  ],

  "db": {
    "tableName": "produccion_resortes",
    "indexes": ["dni", "fecha", "maquina", "producto"]
  },

  "metrics": {
    "kpis": ["produccion_total", "output_promedio", "calidad_a", "top_trabajadores"],
    "aggregations": [
      { "field": "producto", "operation": "sum", "target": "cantidad" },
      { "field": "maquina", "operation": "sum", "target": "outputMaquina" }
    ]
  },

  "kotlinModel": {
    "className": "ProduccionResorte",
    "fields": [
      { "name": "id", "type": "Long", "primary": true },
      { "name": "trabajadorId", "type": "String" },
      { "name": "trabajadorNombre", "type": "String" },
      { "name": "turno", "type": "String" },
      { "name": "fecha", "type": "Long" },
      { "name": "productoNombre", "type": "String" },
      { "name": "cantidad", "type": "Int" },
      { "name": "maquinaId", "type": "String" },
      { "name": "outputMaquina", "type": "Int" },
      { "name": "calidad", "type": "String" },
      { "name": "createdAt", "type": "Long" }
    ]
  }
}