{
  "$schema": "https://isd-colchones.com/schemas/paneles-v1.json",
  "version": "1.0.0",
  "module": "paneles",
  "description": "Producción de paneles para colchones",
  "lastUpdated": "2025-01-15",

  "allowedProductTypes": [
    { "id": "panel_visco", "name": "Panel Visco", "examples": ["Panel Visco 5cm", "Panel Visco 10cm"] },
    { "id": "panel_espuma", "name": "Panel Espuma", "examples": ["Panel Espuma 5cm", "Panel Espuma 10cm"] },
    { "id": "panel_latex", "name": "Panel Latex", "examples": ["Panel Latex natural", "Panel Latex sintético"] },
    { "id": "panel_gel", "name": "Panel Gel", "examples": ["Panel Gel refresh", "Panel Gel plus"] },
    { "id": "panel_memory", "name": "Panel Memory Foam", "examples": ["Memory 5cm", "Memory 10cm"] },
    { "id": "otro", "name": "Otro", "examples": [] }
  ],

  "validation": {
    "required": ["trabajador", "dni", "turno", "fecha", "producto", "cantidad", "maquina", "outputMaquina"],
    "numeric": ["cantidad", "outputMaquina"],
    "dateFormat": "YYYY-MM-DD"
  },

  "fieldMappings": {
    "trabajador": { "aliases": ["trabajador", "worker", "nombre", "name", "empleado"] },
    "dni": { "aliases": ["dni", "cedula", "ci", "id"] },
    "turno": { "aliases": ["turno", "shift", "jornada"] },
    "fecha": { "aliases": ["fecha", "date", "dia"] },
    "producto": { "aliases": ["producto", "tipo", "name", "articulo"] },
    "cantidad": { "aliases": ["cantidad", "qty", "units", "cant"] },
    "maquina": { "aliases": ["maquina", "machine", "equipo"] },
    "outputMaquina": { "aliases": ["outputMaquina", "output", "lecturaMaquina"] },
    "eficiencia": { "aliases": ["eficiencia", "eff", "efficiency"] }
  },

  "turnos": ["Mañana", "Tarde", "Noche"],

  "sampleRecords": [
    {
      "trabajador": "Juan Pérez",
      "dni": "11223344",
      "turno": "Mañana",
      "fecha": "2025-01-15",
      "producto": "Panel Visco 5cm",
      "cantidad": 45,
      "maquina": "PAN-01",
      "outputMaquina": 180,
      "eficiencia": 92
    }
  ],

  "db": {
    "tableName": "produccion_paneles",
    "indexes": ["dni", "fecha", "maquina", "producto"]
  },

  "metrics": {
    "kpis": ["produccion_total", "eficiencia_promedio", "defectos", "top_trabajadores"],
    "aggregations": [
      { "field": "producto", "operation": "sum", "target": "cantidad" },
      { "field": "maquina", "operation": "avg", "target": "eficiencia" }
    ]
  },

  "kotlinModel": {
    "className": "ProduccionPanel",
    "fields": [
      { "name": "id", "type": "Long", "primary": true },
      { "name": "trabajadorId", "type": "String" },
      { "name": "trabajadorNombre", "type": "String" },
      { "name": "turno", "type": "String" },
      { "name": "fecha", "type": "Long" },
      { "name": "productoNombre", "type": "String" },
      { "name": "cantidad", "type": "Int" },
      { "name": "maquinaId", "type": "String" },
      { "name": "outputMaquina", "type": "Int" },
      { "name": "eficiencia", "type": "Double" },
      { "name": "createdAt", "type": "Long" }
    ]
  }
}